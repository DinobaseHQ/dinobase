# Supabase (from Project Settings > API)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

DINOBASE_ENV=development

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
DINOBASE_ENCRYPTION_KEY=

# Storage
DINOBASE_STORAGE_BUCKET=dinobase-cloud
DINOBASE_STORAGE_PREFIX=
# Local dev: use a local directory instead of S3 (no AWS credentials needed).
# Note: if you also run `dinobase serve --sync` locally, make sure this path differs
# from the default dinobase DB (~/.dinobase/dinobase.duckdb) to avoid two processes
# writing to the same DuckDB file concurrently.
DINOBASE_LOCAL_STORAGE_ROOT=

# AWS credentials (required when DINOBASE_LOCAL_STORAGE_ROOT is not set)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=

# Server
DINOBASE_HOST=0.0.0.0
DINOBASE_PORT=8787
DINOBASE_BASE_URL=http://localhost:8787
# Deployment mode: all (default), web, query, or worker
DINOBASE_MODE=all
# URL of the query server (required when DINOBASE_MODE=web to proxy query traffic)
DINOBASE_QUERY_URL=
# Sync worker poll interval in seconds (default 5)
DINOBASE_SYNC_POLL_INTERVAL=5
# Query DB cache TTL in seconds (default 300)
DINOBASE_DB_CACHE_TTL=300

# CORS (comma-separated origins for the web frontend)
DINOBASE_ALLOWED_ORIGINS=http://localhost:3000

# Sandbox (optional — enables the /sandbox endpoint)
ANTHROPIC_API_KEY=
# S3 URL for shared read-only sandbox seed database (populated by scripts/seed_s3.py)
DINOBASE_SEED_STORAGE_URL=

# OAuth provider credentials (one pair per provider you want to enable)
# DINOBASE_OAUTH_HUBSPOT_CLIENT_ID=
# DINOBASE_OAUTH_HUBSPOT_CLIENT_SECRET=
# DINOBASE_OAUTH_GITHUB_CLIENT_ID=
# DINOBASE_OAUTH_GITHUB_CLIENT_SECRET=
# DINOBASE_OAUTH_SALESFORCE_CLIENT_ID=
# DINOBASE_OAUTH_SALESFORCE_CLIENT_SECRET=

# ---------- Public URLs ----------
# Subdomains of your own domain pointed at the Hetzner VM's IPv4 / IPv6.
# Caddy will auto-provision Let's Encrypt certs for both.
DINOBASE_WEB_DOMAIN=dinobase.chloris.co.il
DINOBASE_API_DOMAIN=api.dinobase.chloris.co.il

# Email used by Let's Encrypt for expiry notices.
DINOBASE_ACME_EMAIL=you@chloris.co.il

# Full URLs (with https://) — inlined into the web bundle at build time
# and used by the API for absolute links (OAuth callbacks, email links).
DINOBASE_PUBLIC_WEB_URL=https://dinobase.chloris.co.il
DINOBASE_PUBLIC_API_URL=https://api.dinobase.chloris.co.il

# ---------- API (read by the api/query/worker containers) ----------
DINOBASE_ENV=production
DINOBASE_BASE_URL=https://api.dinobase.chloris.co.il
DINOBASE_ALLOWED_ORIGINS=https://dinobase.chloris.co.il

# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DINOBASE_ENCRYPTION_KEY=

# ---------- Supabase (auth + metadata DB) ----------
# Create a free project at https://supabase.com, then copy from
# Project Settings > API. Add both domains above to
# Authentication > URL Configuration > Redirect URLs.
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

# ---------- Storage ----------
# Default: local disk inside the `dinobase-data` Docker volume (simplest).
# The compose file mounts the volume at /data and sets this var per-service.
# To use Hetzner Object Storage (S3-compatible) instead, clear the volume
# mount in docker-compose.yml and set the AWS_* vars below:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=fsn1
# DINOBASE_STORAGE_BUCKET=dinobase
# DINOBASE_STORAGE_PREFIX=
# (You'll also need to point the dlt/DuckDB S3 endpoint at Hetzner's object
# storage URL — see the self-hosting docs page for the full recipe.)

# ---------- Optional: semantic layer (auto-annotation) ----------
# If set, the worker runs a Claude agent after each sync to annotate schemas.
ANTHROPIC_API_KEY=

# ---------- Optional: analytics ----------
# Leave blank to disable PostHog in the web UI.
NEXT_PUBLIC_POSTHOG_KEY=

# ---------- Optional: OAuth app credentials (one pair per enabled source) ----------
# DINOBASE_OAUTH_HUBSPOT_CLIENT_ID=
# DINOBASE_OAUTH_HUBSPOT_CLIENT_SECRET=
# DINOBASE_OAUTH_GITHUB_CLIENT_ID=
# DINOBASE_OAUTH_GITHUB_CLIENT_SECRET=
# DINOBASE_OAUTH_SALESFORCE_CLIENT_ID=
# DINOBASE_OAUTH_SALESFORCE_CLIENT_SECRET=

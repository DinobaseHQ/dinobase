# Supabase (from Project Settings > API)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

# Web (Next.js) — copy these two into cloud/web/.env.local as NEXT_PUBLIC_ prefixed
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
NEXT_PUBLIC_API_URL=http://localhost:8787

DINOBASE_ENV=development

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
DINOBASE_ENCRYPTION_KEY=

# Storage
DINOBASE_STORAGE_BUCKET=dinobase-cloud

# Server
DINOBASE_HOST=0.0.0.0
DINOBASE_PORT=8787
DINOBASE_BASE_URL=http://localhost:8787

# CORS
DINOBASE_ALLOWED_ORIGINS=http://localhost:3000

# OAuth provider credentials (one pair per provider you want to enable)
# DINOBASE_OAUTH_HUBSPOT_CLIENT_ID=
# DINOBASE_OAUTH_HUBSPOT_CLIENT_SECRET=
# DINOBASE_OAUTH_GITHUB_CLIENT_ID=
# DINOBASE_OAUTH_GITHUB_CLIENT_SECRET=

# API base URL (public — inlined into the client bundle)
NEXT_PUBLIC_API_URL=http://localhost:8787

# Supabase client config (from Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Marketing site URL (used for footer / "back to site" links)
NEXT_PUBLIC_WEBSITE_URL=https://dinobase.ai

# PostHog analytics (optional). Leave blank to disable.
NEXT_PUBLIC_POSTHOG_KEY=

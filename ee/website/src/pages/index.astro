        <script>
            (() => {
                "use strict";

                // Spotlight cursor
                const spotlight = document.getElementById("spotlight");
                document.addEventListener(
                    "mousemove",
                    (e) => {
                        spotlight.style.background = `radial-gradient(500px at ${e.clientX}px ${e.clientY}px, rgba(74,222,128,0.06), transparent 80%)`;
                    },
                    { passive: true },
                );

                // Nav scroll effect
                const nav = document.getElementById("main-nav");
                window.addEventListener(
                    "scroll",
                    () => {
                        nav.classList.toggle("scrolled", window.scrollY > 60);
                    },
                    { passive: true },
                );

                // Hero parallax
                const heroBg = document.querySelector(".hero-bg");
                if (heroBg) {
                    window.addEventListener(
                        "scroll",
                        () => {
                            if (window.scrollY < window.innerHeight * 1.5) {
                                heroBg.style.transform = `translateY(${window.scrollY * 0.25}px)`;
                            }
                        },
                        { passive: true },
                    );
                }

                // Scroll reveal with IntersectionObserver
                const obs = new IntersectionObserver(
                    (entries) => {
                        entries.forEach((e) => {
                            if (e.isIntersecting) {
                                e.target.classList.add("visible");
                                obs.unobserve(e.target);
                            }
                        });
                    },
                    { threshold: 0.07 },
                );

                document
                    .querySelectorAll(".reveal")
                    .forEach((el) => obs.observe(el));
                document.querySelectorAll(".reveal-stagger").forEach((el) => {
                    [...el.children].forEach((c, i) =>
                        c.style.setProperty("--i", i),
                    );
                    obs.observe(el);
                });

                // Magnetic buttons
                document
                    .querySelectorAll(".btn-primary, .btn-cta")
                    .forEach((btn) => {
                        btn.addEventListener("mousemove", (e) => {
                            const r = btn.getBoundingClientRect();
                            const x = (e.clientX - r.left - r.width / 2) * 0.15;
                            const y = (e.clientY - r.top - r.height / 2) * 0.15;
                            btn.style.transform = `translate(${x}px,${y}px)`;
                        });
                        btn.addEventListener("mouseleave", () => {
                            btn.style.transition =
                                "transform 0.5s cubic-bezier(0.22,0.68,0,1.5)";
                            btn.style.transform = "";
                            setTimeout(() => (btn.style.transition = ""), 500);
                        });
                    });

                // Stat counter animation
                const statEls = document.querySelectorAll(
                    ".stat-num[data-target]",
                );
                let statsTriggered = false;

                function animateStat(el, i) {
                    const target = parseInt(el.dataset.target, 10);
                    const suffix = el.dataset.suffix || "";
                    const start = Date.now();
                    const dur = 1500 + i * 120;
                    function frame() {
                        const p = Math.min((Date.now() - start) / dur, 1);
                        const eased = 1 - Math.pow(1 - p, 3);
                        if (p < 0.55) {
                            el.style.opacity = "0.6";
                            el.textContent =
                                Math.floor(Math.random() * (target + 20)) +
                                suffix;
                        } else {
                            el.style.opacity = "";
                            el.textContent =
                                Math.round(eased * target) + suffix;
                        }
                        if (p < 1) requestAnimationFrame(frame);
                        else {
                            el.textContent = target + suffix;
                            el.classList.add("landed");
                            setTimeout(
                                () => el.classList.remove("landed"),
                                300,
                            );
                        }
                    }
                    setTimeout(() => requestAnimationFrame(frame), i * 80);
                }

                new IntersectionObserver(
                    (entries) => {
                        entries.forEach((e) => {
                            if (e.isIntersecting && !statsTriggered) {
                                statsTriggered = true;
                                statEls.forEach((el, i) => animateStat(el, i));
                                setTimeout(() => {
                                    const bm =
                                        document.getElementById("bar-mcp");
                                    const bd =
                                        document.getElementById("bar-dino");
                                    if (bm) bm.style.transform = "scaleX(1)";
                                    if (bd)
                                        setTimeout(
                                            () =>
                                                (bd.style.transform =
                                                    "scaleX(1)"),
                                            200,
                                        );
                                }, 400);
                            }
                        });
                    },
                    { threshold: 0.25 },
                ).observe(document.getElementById("numbers"));

                // Capture PostHog event when Cal booking is confirmed
                window.addEventListener("cal:bookingSuccessful", function (e) {
                    const email = e.detail?.email;
                    if (email && window.posthog) {
                        posthog.identify(email, { email });
                        posthog.capture("waitlist_joined", { email });
                    }
                });

                // Before/After slider
                const sliderWrap = document.getElementById("slider-wrap");
                if (sliderWrap) {
                    const afterPanel = sliderWrap.querySelector(
                        ".slider-panel.after",
                    );
                    const divider = document.getElementById("slider-divider");
                    let dragging = false;

                    function setSliderPos(clientX) {
                        const rect = sliderWrap.getBoundingClientRect();
                        const pct = Math.max(
                            0,
                            Math.min(
                                95,
                                ((clientX - rect.left) / rect.width) * 100,
                            ),
                        );
                        afterPanel.style.clipPath = `inset(0 0 0 ${pct}%)`;
                        divider.style.left = `${pct}%`;
                    }

                    sliderWrap.addEventListener("mousedown", (e) => {
                        dragging = true;
                        setSliderPos(e.clientX);
                    });
                    window.addEventListener("mousemove", (e) => {
                        if (dragging) setSliderPos(e.clientX);
                    });
                    window.addEventListener("mouseup", () => {
                        dragging = false;
                    });
                    sliderWrap.addEventListener(
                        "touchstart",
                        (e) => {
                            dragging = true;
                            setSliderPos(e.touches[0].clientX);
                        },
                        { passive: true },
                    );
                    window.addEventListener(
                        "touchmove",
                        (e) => {
                            if (dragging) setSliderPos(e.touches[0].clientX);
                        },
                        { passive: true },
                    );
                    window.addEventListener("touchend", () => {
                        dragging = false;
                    });

                    // Scroll-triggered intro animation: 60% → 35%
                    let sliderAnimated = false;
                    const sliderObs = new IntersectionObserver(
                        (entries) => {
                            if (sliderAnimated || !entries[0].isIntersecting)
                                return;
                            sliderAnimated = true;
                            sliderObs.disconnect();
                            setTimeout(() => {
                                afterPanel.style.transition =
                                    "clip-path 1.3s ease, left 1.3s ease";
                                divider.style.transition = "left 1.3s ease";
                                afterPanel.style.clipPath = "inset(0 0 0 35%)";
                                divider.style.left = "35%";
                                setTimeout(() => {
                                    afterPanel.style.transition = "";
                                    divider.style.transition = "";
                                }, 1400);
                            }, 500);
                        },
                        { threshold: 0.4 },
                    );
                    sliderObs.observe(sliderWrap);
                }
                // Integration tabs
                document.querySelectorAll(".tab-btn").forEach((btn) => {
                    btn.addEventListener("click", () => {
                        const tab = btn.dataset.tab;
                        const container = btn.closest(".int-tabs");
                        container
                            .querySelectorAll(".tab-btn")
                            .forEach((b) => b.classList.remove("active"));
                        container
                            .querySelectorAll(".tab-panel")
                            .forEach((p) => p.classList.remove("active"));
                        btn.classList.add("active");
                        container
                            .querySelector(`#tab-${tab}`)
                            .classList.add("active");
                    });
                });

                // Email-first Cal.com flow
                const emailModal = document.getElementById("email-modal");
                const emailModalCard =
                    document.getElementById("email-modal-card");
                const emailModalClose =
                    document.getElementById("email-modal-close");
                const emailModalForm =
                    document.getElementById("email-modal-form");
                const emailModalInput =
                    document.getElementById("email-modal-input");
                const emailModalError =
                    document.getElementById("email-modal-error");
                const emailModalBook =
                    document.getElementById("email-modal-book");
                const emailModalSlack =
                    document.getElementById("email-modal-slack");
                const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                let currentSource = null;
                let capturedEmail = null;

                function openEmailModal(source) {
                    currentSource = source || "unknown";
                    emailModalCard.classList.remove("success");
                    emailModal.classList.add("open");
                    emailModal.setAttribute("aria-hidden", "false");
                    emailModalError.textContent = "";
                    emailModalInput.classList.remove("invalid");
                    setTimeout(() => emailModalInput.focus(), 50);
                    if (window.posthog) {
                        window.posthog.capture("cta_modal_opened", {
                            source: currentSource,
                        });
                    }
                }

                function closeEmailModal() {
                    emailModal.classList.remove("open");
                    emailModal.setAttribute("aria-hidden", "true");
                }

                function openCalBooking() {
                    if (
                        window.Cal &&
                        Cal.ns &&
                        Cal.ns["dinobase-15-min-setup"]
                    ) {
                        Cal.ns["dinobase-15-min-setup"]("modal", {
                            calLink: "em-dinobase/dinobase-15-min-setup",
                            config: {
                                layout: "month_view",
                                email: capturedEmail || "",
                            },
                        });
                    }
                }

                document.querySelectorAll(".js-cta-book").forEach((btn) => {
                    btn.addEventListener("click", (e) => {
                        e.preventDefault();
                        openEmailModal(btn.dataset.ctaSource);
                    });
                });

                emailModalClose.addEventListener("click", closeEmailModal);
                emailModal.addEventListener("click", (e) => {
                    if (e.target === emailModal) closeEmailModal();
                });
                document.addEventListener("keydown", (e) => {
                    if (
                        e.key === "Escape" &&
                        emailModal.classList.contains("open")
                    ) {
                        closeEmailModal();
                    }
                });

                emailModalForm.addEventListener("submit", (e) => {
                    e.preventDefault();
                    const email = emailModalInput.value.trim();
                    if (!EMAIL_RE.test(email)) {
                        emailModalInput.classList.add("invalid");
                        emailModalError.textContent =
                            "Please enter a valid email.";
                        emailModalInput.focus();
                        return;
                    }
                    emailModalInput.classList.remove("invalid");
                    emailModalError.textContent = "";
                    capturedEmail = email;

                    if (window.posthog) {
                        try {
                            window.posthog.identify(email, { email });
                            window.posthog.capture("cta_email_submitted", {
                                email,
                                source: currentSource,
                            });
                        } catch (_) {
                            /* no-op */
                        }
                    }

                    emailModalCard.classList.add("success");
                });

                emailModalSlack.addEventListener("click", () => {
                    if (window.posthog) {
                        window.posthog.capture("cta_slack_clicked", {
                            source: currentSource,
                            email: capturedEmail,
                        });
                    }
                    closeEmailModal();
                });

                emailModalBook.addEventListener("click", () => {
                    if (window.posthog) {
                        window.posthog.capture("cta_book_call_clicked", {
                            source: currentSource,
                            email: capturedEmail,
                        });
                    }
                    closeEmailModal();
                    openCalBooking();
                });
            })();
        </script>

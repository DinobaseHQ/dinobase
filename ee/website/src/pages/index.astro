                    <div class="sem-pane bad">
                        <p class="sem-head">✗ Raw SQL without context</p>
                        <pre
                            class="code-block">subscriptions
  id          VARCHAR
  customer_id VARCHAR
  plan_id     VARCHAR
  status      VARCHAR
  created     INTEGER</pre>
                        <p class="sem-note">
                            Agent has to guess: what is <code>created</code>?
                            Unix? ISO? What values does <code>status</code> accept?
                            How does <code>customer_id</code> join?
                        </p>
                    </div>
                    <div class="sem-pane good">
                        <p class="sem-head">✓ Dinobase semantic layer</p>
                        <pre
                            class="code-block">stripe.subscriptions — "Active and historical subscriptions"

  customer_id  VARCHAR  → stripe.customers.id  [FK]
  plan_id      VARCHAR  → stripe.plans.id       [FK]
  status       VARCHAR  "active|past_due|canceled|trialing"
  created      INTEGER  "Unix timestamp — use to_timestamp()"
  amount       INTEGER  "Amount in cents"

Related: stripe.customers, stripe.invoices</pre>
                        <p class="sem-note">
                            Agent knows the join path, the enum values, the
                            timestamp format, and which fields are PII — before
                            writing a single query.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- NUMBERS -->
        <div class="section-wrap numbers-section reveal" id="numbers">
            <div class="container">
                <p class="section-no">03 — benchmarks</p>
                <h2>
                    Numbers that <span class="h-word">justify</span> the switch.
                </h2>
                <div class="stats-row reveal-stagger">
                    <div class="stat-cell">
                        <span class="stat-num" data-target="3" data-suffix="x"
                            >0%</span
                        >
                        <p class="stat-desc">
                            query accuracy across benchmarked LLMs
                        </p>
                    </div>
                    <div class="stat-cell">
                        <span class="stat-num" data-target="10" data-suffix="×"
                            >0×</span
                        >
                        <p class="stat-desc">fewer tokens vs API calling</p>
                    </div>
                    <div class="stat-cell">
                        <span class="stat-num" data-target="50" data-suffix="ms"
                            >&lt;50ms</span
                        >
                        <p class="stat-desc">avg query time</p>
                    </div>
                    <div class="stat-cell">
                        <span class="stat-num" data-target="100" data-suffix="+"
                            >0+</span
                        >
                        <p class="stat-desc">sources synced automatically</p>
                    </div>
                </div>
                <div class="race-wrap">
                    <div class="race-row">
                        <div class="race-labels">
                            <span>MCP / API calling accuracy</span><span
                                style="color:var(--red)">~38%</span
                            >
                        </div>
                        <div class="race-track">
                            <div
                                class="race-bar bad"
                                id="bar-mcp"
                                style="width:38%"
                            >
                                ~38%
                            </div>
                        </div>
                    </div>
                    <div class="race-row">
                        <div class="race-labels">
                            <span>Dinobase query accuracy</span><span
                                style="color:var(--green)">91%</span
                            >
                        </div>
                        <div class="race-track">
                            <div
                                class="race-bar good"
                                id="bar-dino"
                                style="width:91%"
                            >
                                91%
                            </div>
                        </div>
                    </div>
                    <p class="race-footnote">
                        benchmarked on the <a
                            href="https://github.com/DinobaseHQ/dinobase/tree/main/benchmarks"
                            target="_blank">Dinobase eval suite</a
                        > · 10+ LLMs including GPT-5.4, Claude 4.6, Gemini 3
                    </p>
                </div>
            </div>
        </div>

        <!-- INSTALL -->
        <div class="section-wrap reveal" id="install">
            <div class="container">
                <p class="section-no">04 — setup</p>
                <h2>
                    One line to <span class="h-word">connect</span> your agent.
                </h2>
                <div class="section-sub">
                    <p>
                        Works with Claude Code, Claude Desktop, Cursor, OpenClaw
                        and more — one command to connect.
                    </p>
                    <a
                        href="/docs/getting-started/#set-up-an-agent"
                        class="section-sub-btn btn-ghost">Read the docs →</a
                    >
                </div>
                <div class="install-list reveal-stagger">
                    <div class="install-item">
                        <span class="install-num">01</span>
                        <div class="install-body">
                            <h3>Claude Code</h3>
                            <p class="install-tag">Anthropic CLI</p>
                            <pre
                                class="code-block">claude mcp add dinobase -- dinobase serve</pre>
                        </div>
                    </div>
                    <div class="install-item">
                        <span class="install-num">02</span>
                        <div class="install-body">
                            <h3>Claude Desktop &amp; Cursor</h3>
                            <p class="install-tag">dinobase install</p>
                            <pre
                                class="code-block">dinobase install claude-desktop
dinobase install cursor</pre>
                        </div>
                    </div>
                    <div class="install-item">
                        <span class="install-num">03</span>
                        <div class="install-body">
                            <h3>OpenClaw</h3>
                            <p class="install-tag">ClawHub</p>
                            <pre
                                class="code-block">openclaw skills install dinobase</pre>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- FINAL CTA -->
        <div class="cta-section reveal" id="cta">
            <h2>ok. you've read enough.</h2>
            <div class="cta-box">
                <div class="container cta-content">
                    <p class="cta-sub">
                        Stop giving your agents a blindfold. Give them a
                        database.
                    </p>
                    <div class="cta-actions">
                        <form id="footer-waitlist-form" class="waitlist-form">
                            <input
                                type="email"
                                id="footer-email"
                                name="email"
                                placeholder="your@email.com"
                                required
                                autocomplete="email"
                                class="waitlist-input"
                                style="font-size:1rem;"
                            />
                            <button type="submit" class="btn-cta"
                                ><span class="btn-label"
                                    ><span>Join waitlist</span><span
                                        >Join waitlist</span
                                    ></span
                                ></button
                            >
                        </form>
                        <div
                            id="footer-success"
                            class="waitlist-success"
                            style="display:none; font-size:1.125rem;"
                        >
                            ✓ You're on the list.
                        </div>
                        <div
                            id="footer-early-access"
                            style="display:none; flex-direction:column; align-items:center; gap:1rem;"
                        >
                            <a
                                href="https://app.dinobase.ai/login"
                                class="btn-cta">Start building →</a
                            >
                        </div>
                    </div>
                    <p class="self-hosted-note" style="margin-top:2rem">
                        <a href="/docs">Read the docs</a>
                        &nbsp;·&nbsp;
                        <a href="https://github.com/DinobaseHQ/dinobase"
                            >Self-host on GitHub</a
                        >
                    </p>
                </div>
            </div>
            <picture class="cta-dino-wrap">
                <source type="image/avif" srcset="/footer.avif" />
                <source type="image/webp" srcset="/footer.webp" />
                <img src="/footer.png" alt="" class="cta-dino" width="677" height="369" loading="lazy" decoding="async" />
            </picture>
        </div>

        <!-- FOOTER -->
        <footer>
            <a href="/" class="nav-logo" style="gap:0.5rem">
                <img src="/logo.svg" alt="" />
                dinobase
            </a>
            <div class="footer-links">
                <a href="/docs">Docs</a>
                <a href="https://github.com/DinobaseHQ/dinobase">GitHub</a>
            </div>
            <span style="color:var(--dimmed);font-size:0.8125rem"
                >&copy; {new Date().getFullYear()} Dinobase</span
            >
        </footer>

        <script>
            (() => {
                "use strict";

                // Spotlight cursor
                const spotlight = document.getElementById("spotlight");
                document.addEventListener(
                    "mousemove",
                    (e) => {
                        spotlight.style.background = `radial-gradient(500px at ${e.clientX}px ${e.clientY}px, rgba(74,222,128,0.06), transparent 80%)`;
                    },
                    { passive: true },
                );

                // Nav scroll effect
                const nav = document.getElementById("main-nav");
                window.addEventListener(
                    "scroll",
                    () => {
                        nav.classList.toggle("scrolled", window.scrollY > 60);
                    },
                    { passive: true },
                );

                // Hero parallax
                const heroBg = document.querySelector(".hero-bg");
                if (heroBg) {
                    window.addEventListener(
                        "scroll",
                        () => {
                            if (window.scrollY < window.innerHeight * 1.5) {
                                heroBg.style.transform = `translateY(${window.scrollY * 0.25}px)`;
                            }
                        },
                        { passive: true },
                    );
                }

                // Scroll reveal with IntersectionObserver
                const obs = new IntersectionObserver(
                    (entries) => {
                        entries.forEach((e) => {
                            if (e.isIntersecting) {
                                e.target.classList.add("visible");
                                obs.unobserve(e.target);
                            }
                        });
                    },
                    { threshold: 0.07 },
                );

                document
                    .querySelectorAll(".reveal")
                    .forEach((el) => obs.observe(el));
                document.querySelectorAll(".reveal-stagger").forEach((el) => {
                    [...el.children].forEach((c, i) =>
                        c.style.setProperty("--i", i),
                    );
                    obs.observe(el);
                });

                // Magnetic buttons
                document
                    .querySelectorAll(".btn-primary, .btn-cta")
                    .forEach((btn) => {
                        btn.addEventListener("mousemove", (e) => {
                            const r = btn.getBoundingClientRect();
                            const x = (e.clientX - r.left - r.width / 2) * 0.15;
                            const y = (e.clientY - r.top - r.height / 2) * 0.15;
                            btn.style.transform = `translate(${x}px,${y}px)`;
                        });
                        btn.addEventListener("mouseleave", () => {
                            btn.style.transition =
                                "transform 0.5s cubic-bezier(0.22,0.68,0,1.5)";
                            btn.style.transform = "";
                            setTimeout(() => (btn.style.transition = ""), 500);
                        });
                    });

                // Terminal animation
                const termBody = document.getElementById("terminal-body");
                const termDisplay = document.getElementById("terminal-display");
                const cursorLine = document.getElementById(
                    "terminal-cursor-line",
                );

                const SEQUENCE = [
                    {
                        prompt: "$",
                        cmd: "dinobase sync",
                        hist: 'dinobase <span style="color:#60a5fa">sync</span>',
                        out: [
                            {
                                t: '⚡ syncing <span style="color:#fbbf24">stripe</span>...    ✓ <span style="color:#4ade80">12,847</span> rows',
                                c: "tout",
                            },
                            {
                                t: '⚡ syncing <span style="color:#fbbf24">hubspot</span>...   ✓  <span style="color:#4ade80">4,391</span> rows',
                                c: "tout",
                            },
                            {
                                t: '⚡ syncing <span style="color:#fbbf24">zendesk</span>...   ✓  <span style="color:#4ade80">2,209</span> rows',
                                c: "tout",
                            },
                            {
                                t: "✓ ready in 3.2s · semantic layer indexed",
                                c: "tout ok",
                            },
                        ],
                    },
                    {
                        prompt: "[agent]",
                        cmd: "dinobase describe stripe.customers",
                        hist: 'dinobase <span style="color:#60a5fa">describe</span> <span style="color:#fbbf24">stripe.customers</span>',
                        out: [
                            {
                                t: '<span style="color:#fbbf24">stripe.customers</span>  (12,847 rows · synced 2m ago)',
                                c: "tout step",
                            },
                            {
                                t: '  <span style="color:#fff">name</span>     <span style="color:#22d3ee">text</span>  · customer display name  <span style="color:#f97316">[PII]</span>',
                                c: "tout",
                            },
                            {
                                t: '  <span style="color:#fff">mrr</span>      <span style="color:#22d3ee">float</span> · monthly recurring revenue (USD)',
                                c: "tout",
                            },
                            {
                                t: '  <span style="color:#fff">segment</span>  <span style="color:#22d3ee">text</span>  · enterprise | growth | smb',
                                c: "tout",
                            },
                            {
                                t: '  <span style="color:#fff">churned</span>  <span style="color:#22d3ee">bool</span>  · true if subscription cancelled',
                                c: "tout",
                            },
                            { t: "✓ 4 columns described", c: "tout ok" },
                        ],
                    },
                    {
                        prompt: "[agent]",
                        cmd: 'dinobase query "SELECT name, mrr FROM stripe.customers ORDER BY mrr DESC LIMIT 3"',
                        hist: 'dinobase <span style="color:#60a5fa">query</span> <span style="color:#fbbf24">"SELECT name, mrr FROM stripe.cust…"</span>',
                        out: [
                            {
                                t: '<span style="color:#fff">name</span>          | <span style="color:#fff">mrr</span>    | <span style="color:#fff">segment</span>',
                                c: "tout",
                            },
                            {
                                t: "──────────────────────────────────",
                                c: "tout",
                            },
                            {
                                t: 'Globex Corp   | <span style="color:#4ade80">$3,100</span> | enterprise',
                                c: "tout",
                            },
                            {
                                t: 'Umbrella Co.  | <span style="color:#4ade80">$2,450</span> | growth',
                                c: "tout",
                            },
                            {
                                t: 'Initech Ltd   | <span style="color:#4ade80">$1,820</span> | smb',
                                c: "tout",
                            },
                            { t: "✓ 3 rows · 0.3s", c: "tout ok" },
                        ],
                    },
                ];

                function appendLine(html, cls) {
                    const d = document.createElement("div");
                    d.className = cls || "";
                    d.innerHTML = html;
                    termBody.insertBefore(d, cursorLine);
                    termBody.scrollTop = termBody.scrollHeight;
                }

                function typeCmd(cmd, done) {
                    let i = 0;
                    termDisplay.innerHTML = '<span class="tcursor"></span>';
                    const iv = setInterval(() => {
                        if (i < cmd.length) {
                            termDisplay.textContent = cmd.slice(0, ++i);
                            termDisplay.innerHTML +=
                                '<span class="tcursor"></span>';
                        } else {
                            clearInterval(iv);
                            done();
                        }
                    }, 36);
                }

                function runStep(idx) {
                    if (idx >= SEQUENCE.length) {
                        cursorLine.style.display = "none";
                        setTimeout(() => {
                            termBody
                                .querySelectorAll(".tline,.tout")
                                .forEach((n) => n !== cursorLine && n.remove());
                            cursorLine.style.display = "";
                            termDisplay.innerHTML =
                                '<span class="tcursor"></span>';
                            const termPrompt =
                                document.getElementById("terminal-prompt");
                            termPrompt.textContent = "$";
                            termPrompt.className = "tprompt";
                            runStep(0);
                        }, 3500);
                        return;
                    }
                    const s = SEQUENCE[idx];
                    const termPrompt =
                        document.getElementById("terminal-prompt");
                    termPrompt.textContent = s.prompt || "$";
                    termPrompt.className =
                        "tprompt" + (s.prompt === "[agent]" ? " agent" : "");
                    setTimeout(
                        () => {
                            typeCmd(s.cmd, () => {
                                const pCls =
                                    s.prompt === "[agent]" ? " agent" : "";
                                const histText =
                                    s.hist ||
                                    (s.cmd.length > 55
                                        ? s.cmd.slice(0, 55) + "…"
                                        : s.cmd);
                                appendLine(
                                    `<span class="tprompt${pCls}">${s.prompt || "$"}</span>&nbsp;<span class="ttext">${histText}</span>`,
                                    "tline",
                                );
                                termDisplay.innerHTML =
                                    '<span class="tcursor"></span>';
                                s.out.forEach((line, li) => {
                                    setTimeout(
                                        () => {
                                            const text =
                                                typeof line === "string"
                                                    ? line
                                                    : line.t;
                                            const cls =
                                                typeof line === "string"
                                                    ? "tout"
                                                    : line.c;
                                            appendLine(text, cls);
                                            if (li === s.out.length - 1)
                                                setTimeout(
                                                    () => runStep(idx + 1),
                                                    1200,
                                                );
                                        },
                                        140 + li * 110,
                                    );
                                });
                            });
                        },
                        idx === 0 ? 700 : 500,
                    );
                }
                runStep(0);

                // Stat counter animation
                const statEls = document.querySelectorAll(
                    ".stat-num[data-target]",
                );
                let statsTriggered = false;

                function animateStat(el, i) {
                    const target = parseInt(el.dataset.target, 10);
                    const suffix = el.dataset.suffix || "";
                    const start = Date.now();
                    const dur = 1500 + i * 120;
                    function frame() {
                        const p = Math.min((Date.now() - start) / dur, 1);
                        const eased = 1 - Math.pow(1 - p, 3);
                        if (p < 0.55) {
                            el.style.opacity = "0.6";
                            el.textContent =
                                Math.floor(Math.random() * (target + 20)) +
                                suffix;
                        } else {
                            el.style.opacity = "";
                            el.textContent =
                                Math.round(eased * target) + suffix;
                        }
                        if (p < 1) requestAnimationFrame(frame);
                        else {
                            el.textContent = target + suffix;
                            el.classList.add("landed");
                            setTimeout(
                                () => el.classList.remove("landed"),
                                300,
                            );
                        }
                    }
                    setTimeout(() => requestAnimationFrame(frame), i * 80);
                }

                new IntersectionObserver(
                    (entries) => {
                        entries.forEach((e) => {
                            if (e.isIntersecting && !statsTriggered) {
                                statsTriggered = true;
                                statEls.forEach((el, i) => animateStat(el, i));
                                setTimeout(() => {
                                    const bm =
                                        document.getElementById("bar-mcp");
                                    const bd =
                                        document.getElementById("bar-dino");
                                    if (bm) bm.style.transform = "scaleX(1)";
                                    if (bd)
                                        setTimeout(
                                            () =>
                                                (bd.style.transform =
                                                    "scaleX(1)"),
                                            200,
                                        );
                                }, 400);
                            }
                        });
                    },
                    { threshold: 0.25 },
                ).observe(document.getElementById("numbers"));

                // Waitlist session state
                if (sessionStorage.getItem("waitlist_joined")) {
                    ["hero-waitlist-form", "footer-waitlist-form"].forEach(
                        (id) => {
                            const f = document.getElementById(id);
                            if (f) f.style.display = "none";
                        },
                    );
                    const hs = document.getElementById("hero-success");
                    if (hs) hs.style.display = "block";
                    const fs = document.getElementById("footer-success");
                    if (fs) {
                        fs.style.display = "block";
                        fs.style.fontSize = "1.125rem";
                    }
                    const gl = document.getElementById("footer-ghost-link");
                    if (gl) gl.style.display = "none";
                }

                function handleWaitlist(emailId, formId, successId) {
                    return (e) => {
                        e.preventDefault();
                        const ei = document.getElementById(emailId);
                        const form = document.getElementById(formId);
                        const succ = document.getElementById(successId);
                        if (!ei || !form || !succ) return;
                        const email = ei.value.trim();
                        if (!email) return;
                        const btn = form.querySelector('button[type="submit"]');
                        if (btn) {
                            btn.disabled = true;
                        }
                        if (window.posthog) {
                            posthog.identify(email, { email });
                            posthog.capture("waitlist_joined", { email });
                        }
                        form.style.display = "none";
                        succ.style.display = "block";
                        sessionStorage.setItem("waitlist_joined", "1");
                        if (formId === "footer-waitlist-form") {
                            const gl =
                                document.getElementById("footer-ghost-link");
                            if (gl) gl.style.display = "none";
                        }
                    };
                }

                const hf = document.getElementById("hero-waitlist-form");
                if (hf)
                    hf.addEventListener(
                        "submit",
                        handleWaitlist(
                            "hero-email",
                            "hero-waitlist-form",
                            "hero-success",
                        ),
                    );
                const ff = document.getElementById("footer-waitlist-form");
                if (ff)
                    ff.addEventListener(
                        "submit",
                        handleWaitlist(
                            "footer-email",
                            "footer-waitlist-form",
                            "footer-success",
                        ),
                    );

                function handleNavClick(e) {
                    const hf = document.getElementById("hero-waitlist-form");
                    if (hf && hf.style.display !== "none") {
                        e.preventDefault();
                        const inp = document.getElementById("hero-email");
                        if (inp) inp.focus();
                        document
                            .getElementById("hero")
                            .scrollIntoView({ behavior: "smooth" });
                    }
                }
                const nc = document.getElementById("nav-cta");
                if (nc) nc.addEventListener("click", handleNavClick);

                function applyEarlyAccess() {
                    if (
                        !window.posthog ||
                        !posthog.isFeatureEnabled("early_access")
                    )
                        return;
                    const nc = document.getElementById("nav-cta");
                    if (nc) {
                        nc.textContent = "Get started free";
                        nc.href = "https://app.dinobase.ai/login";
                        nc.removeEventListener("click", handleNavClick);
                    }
                    const hwf = document.getElementById("hero-waitlist-form");
                    if (hwf) hwf.style.display = "none";
                    const ha = document.getElementById("hero-early-access");
                    if (ha) ha.style.display = "inline-flex";
                    const fwf = document.getElementById("footer-waitlist-form");
                    if (fwf) fwf.style.display = "none";
                    const gl = document.getElementById("footer-ghost-link");
                    if (gl) gl.style.display = "none";
                    const fa = document.getElementById("footer-early-access");
                    if (fa) fa.style.display = "flex";
                }

                // Before/After slider
                const sliderWrap = document.getElementById("slider-wrap");
                if (sliderWrap) {
                    const afterPanel = sliderWrap.querySelector(
                        ".slider-panel.after",
                    );
                    const divider = document.getElementById("slider-divider");
                    let dragging = false;

                    function setSliderPos(clientX) {
                        const rect = sliderWrap.getBoundingClientRect();
                        const pct = Math.max(
                            0,
                            Math.min(
                                95,
                                ((clientX - rect.left) / rect.width) * 100,
                            ),
                        );
                        afterPanel.style.clipPath = `inset(0 0 0 ${pct}%)`;
                        divider.style.left = `${pct}%`;
                    }

                    sliderWrap.addEventListener("mousedown", (e) => {
                        dragging = true;
                        setSliderPos(e.clientX);
                    });
                    window.addEventListener("mousemove", (e) => {
                        if (dragging) setSliderPos(e.clientX);
                    });
                    window.addEventListener("mouseup", () => {
                        dragging = false;
                    });
                    sliderWrap.addEventListener(
                        "touchstart",
                        (e) => {
                            dragging = true;
                            setSliderPos(e.touches[0].clientX);
                        },
                        { passive: true },
                    );
                    window.addEventListener(
                        "touchmove",
                        (e) => {
                            if (dragging) setSliderPos(e.touches[0].clientX);
                        },
                        { passive: true },
                    );
                    window.addEventListener("touchend", () => {
                        dragging = false;
                    });

                    // Scroll-triggered intro animation: 60% → 35%
                    let sliderAnimated = false;
                    const sliderObs = new IntersectionObserver(
                        (entries) => {
                            if (sliderAnimated || !entries[0].isIntersecting)
                                return;
                            sliderAnimated = true;
                            sliderObs.disconnect();
                            setTimeout(() => {
                                afterPanel.style.transition =
                                    "clip-path 1.3s ease, left 1.3s ease";
                                divider.style.transition = "left 1.3s ease";
                                afterPanel.style.clipPath = "inset(0 0 0 35%)";
                                divider.style.left = "35%";
                                setTimeout(() => {
                                    afterPanel.style.transition = "";
                                    divider.style.transition = "";
                                }, 1400);
                            }, 500);
                        },
                        { threshold: 0.4 },
                    );
                    sliderObs.observe(sliderWrap);
                }
                window.addEventListener("posthog:ready", applyEarlyAccess);
                if (window.__posthogReady) applyEarlyAccess();
            })();
        </script>
    </body>
</html>

---
const posthogKey = import.meta.env.PUBLIC_POSTHOG_KEY ?? "";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Join the waitlist — Dinobase</title>
        <meta
            name="description"
            content="Join the Dinobase waitlist for early access to the agent-first database."
        />
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
        <link rel="icon" href="/favicon.ico" sizes="any" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400&family=DM+Mono:wght@400;500&display=swap"
            rel="stylesheet"
        />
        <style>
            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            :root {
                --green: #7abf7a;
                --green-accent: #4ade80;
                --bg: #0e1410;
                --surface: #161d13;
                --border: #28342090;
                --border-light: #3a4a30;
                --text: #eceae0;
                --muted: #a8a49a;
                --dimmed: #6b7060;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                background: var(--bg);
                color: var(--text);
                font-family:
                    "Atkinson Hyperlegible",
                    -apple-system,
                    sans-serif;
                line-height: 1.5;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                padding: 2rem 1.5rem;
            }

            .card {
                background: var(--surface);
                border: 1px solid var(--border-light);
                border-radius: 1.25rem;
                width: 100%;
                max-width: 900px;
                overflow: hidden;
            }

            .card-header {
                padding: 3rem 2.5rem 2rem;
                text-align: center;
            }

            .logo {
                font-size: 2.5rem;
                margin-bottom: 1.5rem;
            }

            h1 {
                font-size: 1.75rem;
                font-weight: 700;
                margin-bottom: 0.75rem;
            }

            .subtitle {
                color: var(--muted);
                font-size: 0.9375rem;
                line-height: 1.6;
            }

            .early-access {
                display: none;
                flex-direction: column;
                align-items: center;
                gap: 1rem;
                padding: 0 2.5rem 3rem;
            }

            .early-access p {
                color: var(--muted);
                font-size: 0.9375rem;
            }

            .early-access a {
                display: inline-block;
                background: var(--green);
                color: #0e1410;
                text-decoration: none;
                border-radius: 0.625rem;
                padding: 0.875rem 1.75rem;
                font-size: 0.9375rem;
                font-weight: 700;
                transition: filter 0.15s;
            }

            .early-access a:hover {
                filter: brightness(1.1);
            }

            .back-link {
                display: block;
                margin-top: 1.5rem;
                color: var(--dimmed);
                font-size: 0.875rem;
                text-decoration: none;
            }

            .back-link:hover {
                color: var(--muted);
            }
        </style>
    </head>
    <body>
        <div class="card">
            <div class="card-header">
                <div class="logo">&#x1F995;</div>
                <h1>Book a setup call</h1>
                <p class="subtitle">
                    Dinobase is in early access. Pick a time and we&apos;ll get
                    you set up.
                </p>
            </div>

            <div id="cal-container">
                <div id="my-cal-inline-dinobase-15-min-setup" style="width:100%;height:100%;overflow:scroll"></div>
            </div>

            <div id="early-access" class="early-access">
                <p>You have early access!</p>
                <a href="https://app.dinobase.ai">Get started free &rarr;</a>
            </div>
        </div>

        <a href="/" class="back-link">&larr; Back to dinobase.ai</a>

        <!-- Cal inline embed code begins -->
        <script type="text/javascript">
            (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.eu/embed/embed.js", "init");
            Cal("init", "dinobase-15-min-setup", {origin:"https://app.cal.eu"});
            Cal.ns["dinobase-15-min-setup"]("inline", {
                elementOrSelector: "#my-cal-inline-dinobase-15-min-setup",
                config: {"layout":"month_view","useSlotsViewOnSmallScreen":"true"},
                calLink: "em-dinobase/dinobase-15-min-setup",
            });
            Cal.ns["dinobase-15-min-setup"]("ui", {"hideEventTypeDetails":false,"layout":"month_view"});
            Cal.ns["dinobase-15-min-setup"]("on", {
                action: "bookingSuccessful",
                callback: function (e) {
                    const email = e.detail?.data?.booking?.attendees?.[0]?.email;
                    window.dispatchEvent(new CustomEvent("cal:bookingSuccessful", { detail: { email } }));
                },
            });
        </script>
        <!-- Cal inline embed code ends -->

        <script define:vars={{ posthogKey }}>
            !(function (t, e) {
                var o, n, p, r;
                e.__SV ||
                    ((window.posthog = e),
                    (e._i = []),
                    (e.init = function (i, s, a) {
                        function g(t, e) {
                            var o = e.split(".");
                            2 == o.length && ((t = t[o[0]]), (e = o[1]));
                            t[e] = function () {
                                t.push(
                                    [e].concat(
                                        Array.prototype.slice.call(
                                            arguments,
                                            0,
                                        ),
                                    ),
                                );
                            };
                        }
                        (((p = t.createElement("script")).type =
                            "text/javascript"),
                            (p.crossOrigin = "anonymous"),
                            (p.async = !0),
                            (p.src = s.api_host + "/static/array.js"),
                            (r =
                                t.getElementsByTagName(
                                    "script",
                                )[0]).parentNode.insertBefore(p, r));
                        var u = e;
                        for (
                            void 0 !== a ? (u = e[a] = []) : (a = "posthog"),
                                u.people = u.people || [],
                                u.toString = function (t) {
                                    var e = "posthog";
                                    return (
                                        "posthog" !== a && (e += "." + a),
                                        t || (e += " (stub)"),
                                        e
                                    );
                                },
                                u.people.toString = function () {
                                    return u.toString(1) + " (stub)";
                                },
                                o =
                                    "init me ws register register_once register_for_session unregister opt_out_capturing opt_in_capturing has_opted_out_capturing has_opted_in_capturing reset isFeatureEnabled onFeatureFlags getFeatureFlag getFeatureFlagPayload reloadFeatureFlags group updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures getActiveMatchingSurveys getSurveys getNextSurveyStep onSessionId setPersonProperties".split(
                                        " ",
                                    ),
                                n = 0;
                            n < o.length;
                            n++
                        )
                            g(u, o[n]);
                        e._i.push([i, s, a]);
                    }),
                    (e.__SV = 1));
            })(document, window.posthog || []);

            if (posthogKey) {
                posthog.init(posthogKey, {
                    api_host: "https://f.dinobase.ai",
                    ui_host: "https://us.posthog.com",
                    defaults: "2026-01-30",
                    person_profiles: "identified_only",
                    loaded: function (ph) {
                        ph.onFeatureFlags(function () {
                            window.__posthogReady = true;
                            window.dispatchEvent(new Event("posthog:ready"));
                        });
                    },
                });
            }

            // Capture PostHog event when Cal booking is confirmed
            window.addEventListener("cal:bookingSuccessful", function (e) {
                const email = e.detail?.email;
                console.log(email)
                if (email && window.posthog) {
                    posthog.identify(email, { email });
                    posthog.capture("waitlist_joined", { email });
                }
            });

            // If user already has early_access, hide the calendar
            function applyEarlyAccess() {
                if (!window.posthog || !posthog.isFeatureEnabled("early_access"))
                    return;
                const calContainer = document.getElementById("cal-container");
                const ea = document.getElementById("early-access");
                if (calContainer) calContainer.style.display = "none";
                if (ea) ea.style.display = "flex";
            }

            // Identify from ?email= query param before flags load
            const emailParam = new URLSearchParams(window.location.search).get("email");
            if (emailParam && window.posthog) {
                posthog.identify(emailParam, { email: emailParam });
            }

            window.addEventListener("posthog:ready", applyEarlyAccess);
            if (window.__posthogReady) applyEarlyAccess();
        </script>
    </body>
</html>

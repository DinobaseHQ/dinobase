---
const year = new Date().getFullYear();
const SLACK_INVITE =
    "https://join.slack.com/t/dinobasecommunity/shared_invite/zt-3vd5zvlle-Ys24UiLvbGSg9sxbGMltJA";
const GITHUB = "https://github.com/DinobaseHQ/dinobase";
---

<footer class="site-footer">
    <div class="site-footer-inner">
        <div class="site-footer-top">
            <a href="/" class="site-footer-brand">
                <img src="/logo.svg" alt="" width="28" height="28" />
                <span>dinobase</span>
            </a>
            <a
                href={SLACK_INVITE}
                class="site-footer-cta"
                target="_blank"
                rel="noopener"
            >
                <svg
                    viewBox="0 0 24 24"
                    width="18"
                    height="18"
                    fill="currentColor"
                    aria-hidden="true"
                >
                    <path
                        d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.522h2.52v2.522zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.522 2.527 2.527 0 0 1 2.521 2.522v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zM8.834 6.313a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zM18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zM17.688 8.834a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312zM15.165 18.956a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zM15.165 17.688a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z"
                    ></path>
                </svg>
                <span>Join the Slack community</span>
                <span class="site-footer-cta-arrow">→</span>
            </a>
        </div>

        <div class="site-footer-columns">
            <div class="site-footer-col">
                <h3>Product</h3>
                <ul>
                    <li><a href="/#features">Features</a></li>
                    <li><a href="/docs/integrations/mcp">Integrations</a></li>
                    <li><a href="/docs/connectors/overview">Connectors</a></li>
                    <li><a href="/waitlist">Cloud waitlist</a></li>
                    <li><a href="/install.sh">Install script</a></li>
                </ul>
            </div>
            <div class="site-footer-col">
                <h3>Docs</h3>
                <ul>
                    <li><a href="/docs/getting-started">Getting Started</a></li>
                    <li><a href="/docs/reference/cli">CLI Reference</a></li>
                    <li><a href="/docs/reference/python-api">Python API</a></li>
                    <li><a href="/docs/reference/mcp-tools">MCP Tools</a></li>
                </ul>
            </div>
            <div class="site-footer-col">
                <h3>Community</h3>
                <ul>
                    <li>
                        <a href={SLACK_INVITE} target="_blank" rel="noopener"
                            >Slack</a
                        >
                    </li>
                    <li>
                        <a href={GITHUB} target="_blank" rel="noopener"
                            >GitHub</a
                        >
                    </li>
                    <li>
                        <a
                            href={`${GITHUB}/issues`}
                            target="_blank"
                            rel="noopener">Report an issue</a
                        >
                    </li>
                </ul>
            </div>
        </div>

        <div class="site-footer-bottom">
            <span>&copy; {year} Dinobase</span>
        </div>
    </div>
</footer>

<style>
    .site-footer {
        --footer-bg: #0e1410;
        --footer-border: #28342090;
        --footer-text: #eceae0;
        --footer-muted: #a8a49a;
        --footer-dimmed: #6b7060;
        --footer-accent: #7abf7a;
        --footer-accent-strong: #4ade80;

        background: var(--footer-bg);
        border-top: 1px solid var(--footer-border);
        color: var(--footer-muted);
        font-family:
            "Atkinson Hyperlegible",
            -apple-system,
            BlinkMacSystemFont,
            "Segoe UI",
            sans-serif;
        font-size: 0.875rem;
        line-height: 1.5;
    }

    .site-footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 3rem 2.5rem 1.5rem;
    }

    .site-footer-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
        flex-wrap: wrap;
        padding-bottom: 2.5rem;
        border-bottom: 1px solid var(--footer-border);
    }

    .site-footer-brand {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        color: var(--footer-text);
        text-decoration: none;
        font-weight: 600;
        font-size: 1.05rem;
    }

    .site-footer-brand img {
        display: block;
    }

    .site-footer-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.7rem 1.1rem;
        border: 1px solid var(--footer-accent);
        border-radius: 8px;
        color: var(--footer-accent-strong);
        text-decoration: none;
        font-weight: 600;
        background: rgba(122, 191, 122, 0.08);
        transition:
            background 0.2s ease,
            border-color 0.2s ease,
            transform 0.2s ease;
    }

    .site-footer-cta:hover {
        background: rgba(122, 191, 122, 0.16);
        border-color: var(--footer-accent-strong);
    }

    .site-footer-cta-arrow {
        transition: transform 0.2s ease;
    }

    .site-footer-cta:hover .site-footer-cta-arrow {
        transform: translateX(3px);
    }

    .site-footer-columns {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 2rem;
        padding: 2.5rem 0;
    }

    .site-footer-col h3 {
        margin: 0 0 0.9rem;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--footer-text);
    }

    .site-footer-col ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
    }

    .site-footer-col a {
        color: var(--footer-muted);
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .site-footer-col a:hover {
        color: var(--footer-accent);
    }

    .site-footer-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 1.5rem;
        border-top: 1px solid var(--footer-border);
        color: var(--footer-dimmed);
        font-size: 0.8125rem;
    }

    @media (max-width: 640px) {
        .site-footer-inner {
            padding: 2rem 1.25rem 1.25rem;
        }

        .site-footer-top {
            flex-direction: column;
            align-items: flex-start;
            padding-bottom: 2rem;
        }

        .site-footer-cta {
            width: 100%;
            justify-content: center;
        }

        .site-footer-columns {
            padding: 2rem 0;
        }
    }
</style>
